# =============================================================================
# Grounded LLM — environment template (copy to .env)
# cp .env.example .env
# =============================================================================

SERVER_PORT=8080

# Python RAG service (in Docker use service name "python")
PYTHON_RAG_URL=http://python:5000/rag/context
PYTHON_BASE_URL=http://python:5000
PYTHON_SERVICE_PORT=5000

# LLM (OpenAI-compatible API)
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api
LLM_MODEL=openrouter/free

# Telegram Web App
TELEGRAM_BOT_TOKEN=
TELEGRAM_AUTH_DISABLED=false
TELEGRAM_INIT_DATA_MAX_AGE_SEC=86400

CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1
RATE_LIMIT_REQUESTS_PER_MINUTE=30

DATABASE_URL=postgres://grounded:grounded@postgres:5432/grounded?sslmode=disable
UPLOAD_DIR=/data/uploads
DATA_DIR=/app/data

# JSON configs (optional)
# DOMAINS_CONFIG_PATH=config/domains.json
# LOCALES_ROOT=config/locales
# DEFAULT_LOCALE=en
# CONFIG_RELOAD_INTERVAL_SEC=0

FORCE_RAG_REINDEX=false

# Vector store (Python RAG) — see docs/en/VECTOR_STORE.md
# VECTOR_STORE=chroma
# CHROMA_PERSIST_DIR=./chroma_db
# VECTOR_STORE=qdrant
# QDRANT_URL=http://127.0.0.1:6333
# QDRANT_COLLECTION=grounded_llm
# RAG_RETRIEVAL_MODE=vector   # legacy: hybrid sets keyword rerank when RAG_RERANKER unset
# RAG_RERANKER=none           # none | keyword | cross_encoder
# RAG_CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

ADMIN_USER=admin
ADMIN_PASSWORD=
ADMIN_SECRET=

# ADMIN_USERS_FILE=config/admin_users.json
# TENANT_QUOTAS_FILE=config/tenant_quotas.json

# OIDC SSO for admin UI (optional — see config/SSO.md)
# OIDC_ENABLED=true
# OIDC_ISSUER=https://login.microsoftonline.com/{tenant}/v2.0
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URL=https://your-host/api/admin/auth/callback
# OIDC_SESSION_SECRET=
# OIDC_ROLE_MAPPING_FILE=config/oidc_role_mapping.json
# OIDC_SESSION_TTL_HOURS=12

# External API + multi-tenant
# API_KEYS=key1:label1,key2:label2
# API_KEYS_FILE=config/api_keys.json
DEFAULT_TENANT_ID=default
# ALLOWED_TENANTS=default,acme

# CI / smoke only — deterministic RAG+LLM without external services (never in production)
# LLM_MOCK=true
# RAG_MOCK=true

# Internal auth between Go server and Python RAG (recommended in production)
# RAG_SERVICE_TOKEN=

# Data retention (0 = disabled). Purge runs every RETENTION_INTERVAL_HOURS.
# MESSAGE_RETENTION_DAYS=90
# SESSION_RETENTION_DAYS=365
# RETENTION_INTERVAL_HOURS=24

# SharePoint Graph connector (optional — see docs/en/CONNECTORS.md)
# SHAREPOINT_TENANT_ID=
# SHAREPOINT_CLIENT_ID=
# SHAREPOINT_CLIENT_SECRET=
# SHAREPOINT_DRIVE_ID=
# SHAREPOINT_FOLDER_PATH=
